<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="turbo-visit-control" content="reload">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: 'Arial', sans-serif;
      color: #333;
      background: white;
      padding: 40px;
    }
    
    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 4px solid #f5576c;
      padding-bottom: 20px;
      margin-bottom: 40px;
    }
    
    .logo {
      width: 120px;
      height: 120px;
    }
    
    .header-info {
      text-align: right;
    }
    
    .header-info h1 {
      color: #f5576c;
      font-size: 28px;
      margin-bottom: 8px;
    }
    
    .header-info p {
      color: #666;
      font-size: 14px;
    }
    
    .summary {
      background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
      color: white;
      padding: 30px;
      border-radius: 12px;
      margin-bottom: 40px;
      box-shadow: 0 4px 12px rgba(245, 87, 108, 0.3);
    }
    
    .summary h2 {
      font-size: 24px;
      margin-bottom: 20px;
    }
    
    .summary-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
    
    .summary-item {
      background: rgba(255, 255, 255, 0.2);
      padding: 15px;
      border-radius: 8px;
      text-align: center;
    }
    
    .summary-item .number {
      font-size: 36px;
      font-weight: bold;
      display: block;
      margin-bottom: 5px;
    }
    
    .summary-item .label {
      font-size: 14px;
      opacity: 0.9;
    }
    
    <% if @test_plan.all_scenarios_approved? %>
    .stamp {
      position: absolute;
      top: 80px;
      right: 60px;
      transform: rotate(12deg);
      border: 6px solid #22c55e;
      background: rgba(34, 197, 94, 0.1);
      color: #22c55e;
      padding: 20px 30px;
      border-radius: 12px;
      font-weight: bold;
      text-align: center;
      box-shadow: 0 4px 12px rgba(34, 197, 94, 0.4);
    }
    
    .stamp .title {
      font-size: 32px;
      margin-bottom: 5px;
    }
    
    .stamp .date {
      font-size: 12px;
      margin-bottom: 3px;
    }
    
    .stamp .by {
      font-size: 10px;
    }
    <% end %>
    
    .scenario {
      background: white;
      border: 2px solid #e5e7eb;
      border-radius: 12px;
      padding: 25px;
      margin-bottom: 30px;
      page-break-inside: avoid;
      position: relative;
    }
    
    .scenario-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 20px;
      padding-bottom: 15px;
      border-bottom: 2px solid #f3f4f6;
    }
    
    .scenario-title {
      font-size: 20px;
      font-weight: bold;
      color: #1f2937;
      flex: 1;
    }
    
    .scenario-status {
      padding: 8px 20px;
      border-radius: 20px;
      font-size: 14px;
      font-weight: bold;
      text-transform: uppercase;
    }
    
    .status-approved {
      background: #dcfce7;
      color: #166534;
    }
    
    .status-failed {
      background: #fee2e2;
      color: #991b1b;
    }
    
    .status-pending {
      background: #fef3c7;
      color: #92400e;
    }
    
    .scenario-steps {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 15px;
      margin-bottom: 20px;
    }
    
    .step {
      background: #f9fafb;
      padding: 15px;
      border-radius: 8px;
      border-left: 4px solid;
    }
    
    .step-given {
      border-left-color: #3b82f6;
    }
    
    .step-when {
      border-left-color: #8b5cf6;
    }
    
    .step-then {
      border-left-color: #22c55e;
    }
    
    .step-label {
      font-weight: bold;
      font-size: 12px;
      text-transform: uppercase;
      margin-bottom: 8px;
      color: #666;
    }
    
    .step-content {
      font-size: 14px;
      line-height: 1.5;
      color: #374151;
    }
    
    .evidences {
      margin-top: 20px;
    }
    
    .evidences-title {
      font-weight: bold;
      font-size: 14px;
      margin-bottom: 10px;
      color: #666;
    }
    
    .evidence-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 10px;
    }
    
    .evidence-item {
      width: 100%;
      height: 120px;
      object-fit: cover;
      border-radius: 8px;
      border: 2px solid #e5e7eb;
    }
    
    .evidence-placeholder {
      width: 100%;
      height: 120px;
      background: #f3f4f6;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 40px;
      border: 2px solid #e5e7eb;
    }
    
    .toc {
      background: #f9fafb;
      border: 2px solid #e5e7eb;
      border-radius: 12px;
      padding: 25px;
      margin-bottom: 40px;
    }

    .toc-title {
      font-size: 18px;
      font-weight: bold;
      color: #1f2937;
      margin-bottom: 16px;
      padding-bottom: 12px;
      border-bottom: 2px solid #e5e7eb;
    }

    .toc-table {
      width: 100%;
      border-collapse: collapse;
    }

    .toc-table tr {
      border-bottom: 1px solid #f3f4f6;
    }

    .toc-table tr:last-child {
      border-bottom: none;
    }

    .toc-table td {
      padding: 8px 4px;
      vertical-align: middle;
    }

    .toc-number {
      width: 32px;
      text-align: center;
      font-weight: bold;
      font-size: 14px;
    }

    .toc-number a {
      color: #f5576c;
      text-decoration: none;
      cursor: pointer;
    }

    .toc-name {
      font-size: 14px;
      color: #1f2937;
    }

    .toc-name a {
      color: #1f2937;
      text-decoration: none;
    }

    .toc-name a:hover {
      color: #f5576c;
      text-decoration: underline;
    }

    .toc-status {
      width: 110px;
      text-align: right;
    }

    .toc-badge {
      display: inline-block;
      padding: 4px 12px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: bold;
      text-transform: uppercase;
    }

    .footer {
      margin-top: 60px;
      padding-top: 20px;
      border-top: 2px solid #e5e7eb;
      text-align: center;
      color: #666;
      font-size: 12px;
    }
    
    @media print {
      body {
        padding: 20px;
      }
      
      .scenario {
        page-break-inside: avoid;
      }
    }
  </style>
</head>
<body>
  <% if @test_plan.all_scenarios_approved? %>
  <div class="stamp">
    <div class="title">DONE</div>
    <div class="date"><%= Date.today.strftime('%b %d, %Y').upcase %></div>
    <div class="by">by <%= @test_plan.qa_name %></div>
  </div>
  <% end %>

  <div class="header">
    <div class="logo">
      <svg viewBox="0 0 220 220" xmlns="http://www.w3.org/2000/svg" width="120" height="120">
        <defs>
          <linearGradient id="reportGrad" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" style="stop-color:#f093fb"/>
            <stop offset="100%" style="stop-color:#f5576c"/>
          </linearGradient>
        </defs>
        <rect x="30" y="30" width="160" height="160" rx="20" fill="none" stroke="url(#reportGrad)" stroke-width="8" transform="rotate(-5 110 110)"/>
        <path d="M 75 110 L 95 130 L 145 80" stroke="url(#reportGrad)" stroke-width="12" stroke-linecap="round" stroke-linejoin="round" fill="none" transform="rotate(-5 110 110)"/>
        <text x="110" y="175" font-family="Arial Black, Arial" font-size="32" font-weight="900" fill="url(#reportGrad)" text-anchor="middle" transform="rotate(-5 110 175)">testy</text>
      </svg>
    </div>
    <div class="header-info">
      <h1>Test Report</h1>
      <p>Generated on <%= Date.today.strftime('%m/%d/%Y') %></p>
    </div>
  </div>

  <div class="summary">
    <h2><%= @test_plan.name %></h2>
    <% if @test_plan.tags.any? %>
      <div style="margin-bottom: 15px;">
        <% @test_plan.tags.each do |tag| %>
          <span style="display: inline-block; background: rgba(255,255,255,0.25); color: white; font-size: 12px; font-weight: bold; padding: 4px 12px; border-radius: 20px; margin-right: 6px;"><%= tag.name %></span>
        <% end %>
      </div>
    <% end %>
    <div class="summary-grid">
      <div class="summary-item">
        <span class="number"><%= @test_plan.total_scenarios %></span>
        <span class="label">Total Cases</span>
      </div>
      <div class="summary-item">
        <span class="number"><%= @test_plan.approved_scenarios %></span>
        <span class="label">Approved</span>
      </div>
      <div class="summary-item">
        <span class="number"><%= @test_plan.qa_name %></span>
        <span class="label">Responsible QA</span>
      </div>
    </div>
  </div>

  <% scenarios = @test_plan.test_scenarios.to_a %>
  <% if scenarios.size > 1 %>
  <div class="toc">
    <div class="toc-title">Scenario Index</div>
    <table class="toc-table">
      <% scenarios.each_with_index do |s, i| %>
        <tr>
          <td class="toc-number"><a href="#scenario-<%= i + 1 %>" data-turbo="false"><%= i + 1 %></a></td>
          <td class="toc-name"><a href="#scenario-<%= i + 1 %>" data-turbo="false"><%= s.title %></a></td>
          <td class="toc-status">
            <span class="toc-badge status-<%= s.status %>">
              <%= s.status == 'approved' ? '✓ Approved' : s.status == 'failed' ? '✗ Failed' : '⋯ Pending' %>
            </span>
          </td>
        </tr>
      <% end %>
    </table>
  </div>
  <% end %>

  <% scenarios.each_with_index do |scenario, index| %>
    <div class="scenario" id="scenario-<%= index + 1 %>">
      <div class="scenario-header">
        <div class="scenario-title">
          <%= index + 1 %>. <%= scenario.title %>
        </div>
        <div class="scenario-status status-<%= scenario.status %>">
          <%= scenario.status == 'approved' ? '✓ Approved' : scenario.status == 'failed' ? '✗ Failed' : '⋯ Pending' %>
        </div>
      </div>
      
      <div class="scenario-steps">
        <div class="step step-given">
          <div class="step-label">Given</div>
          <div class="step-content"><%= scenario.given %></div>
        </div>
        
        <div class="step step-when">
          <div class="step-label">When</div>
          <div class="step-content"><%= scenario.when_step %></div>
        </div>
        
        <div class="step step-then">
          <div class="step-label">Then</div>
          <div class="step-content"><%= scenario.then_step %></div>
        </div>
      </div>
      
      <% if scenario.evidence_files.attached? %>
        <div class="evidences">
          <div class="evidences-title">📎 Attached Evidence:</div>
          <div class="evidence-grid">
            <% scenario.evidence_files.first(4).each do |file| %>
              <% if file.image? %>
                <%= image_tag url_for(file), class: "evidence-item" %>
              <% else %>
                <div class="evidence-placeholder">📄</div>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <div class="footer">
    <p><strong>Testy</strong> | Test Management Made Simple</p>
  </div>

  <script>
    document.querySelectorAll('.toc-name a').forEach(function(link) {
      link.addEventListener('click', function(e) {
        e.preventDefault();
        var target = document.querySelector(this.getAttribute('href'));
        if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });
  </script>
</body>
</html>