<div class="page" data-controller="scenario" data-scenario-test-plan-id-value="<%= @test_plan.id %>">
  <div class="page__container">
    <div class="mb-4">
      <%= link_to root_path, class: "page__back", data: { controller: "keyboard-shortcut", keyboard_shortcut_key_value: "b" } do %>
        &larr; <%= t('test_plans.show.back') %>
        <span class="kbd">B</span>
      <% end %>
    </div>

    <div class="panel mb-8 relative">
      <div id="stamp-container" data-scenario-target="stamp" class="hidden stamp">
        <div class="stamp__inner">
          <div class="stamp__title"><%= t('test_plans.show.done') %></div>
          <div class="stamp__date"><%= l(Date.today, format: :short_date).upcase %></div>
          <div class="stamp__by">by <%= @test_plan.qa_name %></div>
        </div>
      </div>

      <h1 class="text-3xl font-black mb-2"><%= @test_plan.name %></h1>
      <p class="txt-ink-dark"><%= t('test_plans.show.responsible_qa') %> <span class="font-semibold"><%= @test_plan.qa_name %></span></p>
      <p class="txt-ink-medium text-sm mt-2">
        <%= t('test_plans.show.scenarios_approved', approved: @test_plan.approved_scenarios, total: @test_plan.total_scenarios) %>
      </p>
      <% if @test_plan.tags.any? %>
        <div class="flex flex-wrap gap-2 mt-3">
          <% @test_plan.tags.each do |tag| %>
            <%= link_to tag.name, test_plans_path(tag: tag.name), class: tag_classes(:violet) %>
          <% end %>
        </div>
      <% end %>
    </div>

    <% if current_user_admin? || @test_plan.user == Current.user %>
      <%= render "test_plans/ai_generation_form", test_plan: @test_plan %>
      <%= render "test_plans/new_scenario_form", test_plan: @test_plan, new_scenario: @new_scenario %>
    <% end %>

    <div class="stack--lg" id="scenarios-container" data-scenario-target="container" data-controller="sortable" data-sortable-url-value="<%= test_plan_scenario_order_path(@test_plan) %>">
      <% @test_scenarios.each do |scenario| %>
        <%= render "test_plans/scenario_card", scenario: scenario, test_plan: @test_plan %>
      <% end %>
    </div>

    <%= render "test_plans/export_buttons", test_scenarios: @test_scenarios, test_plan: @test_plan %>
  </div>
</div>

<script>
  // Update file counter
  document.getElementById('file-upload')?.addEventListener('change', function(e) {
    const count = e.target.files.length;
    const translations = JSON.parse(document.querySelector('meta[name="translations"]')?.content || '{}');
    const fileUpload = translations.file_upload || {};
    const text = count === 0 ? (fileUpload.no_file || 'No file selected') :
                 count === 1 ? (fileUpload.one_file || '1 file selected') :
                 (fileUpload.files || '%{count} files selected').replace('%{count}', count);
    document.getElementById('file-count').textContent = text;
  });
</script>
