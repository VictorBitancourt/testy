<div class="min-h-screen bg-canvas pb-12 px-4" style="padding-top: 90px;" data-controller="scenario">
  <div class="max-w-6xl mx-auto">
    <!-- Back -->
    <div class="mb-4">
      <%= link_to root_path, class: "text-fz-blue-light hover:text-fz-blue-dark font-semibold inline-flex items-center gap-2", data: { controller: "keyboard-shortcut", keyboard_shortcut_key_value: "b" } do %>
        ← Back
        <span class="bg-white/20 text-fz-blue-light text-xs font-bold px-1.5 py-0.5 rounded">B</span>
      <% end %>
    </div>

    <!-- Header -->
    <div class="bg-surface rounded-xl shadow-lg p-6 mb-8 relative">
      <div id="stamp-container" data-scenario-target="stamp" class="hidden absolute -top-6 -right-6">
        <div class="bg-fz-green-dark text-white px-8 py-4 rounded-xl shadow-2xl transform rotate-12 border-4 border-fz-green-darker">
          <div class="text-center">
            <div class="text-3xl font-bold">DONE</div>
            <div class="text-sm"><%= Date.today.strftime('%b %d, %Y').upcase %></div>
            <div class="text-xs">by <%= @test_plan.qa_name %></div>
          </div>
        </div>
      </div>

      <h1 class="text-3xl font-bold text-ink-darkest mb-2"><%= @test_plan.name %></h1>
      <p class="text-ink-dark">Responsible QA: <span class="font-semibold"><%= @test_plan.qa_name %></span></p>
      <p class="text-ink-medium text-sm mt-2">
        <%= @test_plan.approved_scenarios %>/<%= @test_plan.total_scenarios %> scenarios approved
      </p>
      <% if @test_plan.tags.any? %>
        <div class="flex flex-wrap gap-2 mt-3">
          <% @test_plan.tags.each do |tag| %>
            <%= link_to tag.name, test_plans_path(tag: tag.name), class: "inline-block bg-fz-violet-darkest text-fz-violet-light text-sm font-semibold px-3 py-1 rounded-full hover:bg-fz-violet-darker transition" %>
          <% end %>
        </div>
      <% end %>
    </div>

    <% if current_user_admin? || @test_plan.user == Current.user %>
      <!-- New scenario form -->
      <div class="bg-surface rounded-xl shadow-lg p-6 mb-8">
        <h2 class="text-xl font-bold text-ink-darkest mb-4">+ Add New Scenario</h2>

        <%= form_with model: [@test_plan, @new_scenario], class: "space-y-4" do |f| %>
          <div>
            <%= f.label :title, "Scenario Title", class: "block font-semibold text-ink-darker mb-2" %>
            <%= f.text_field :title, class: "w-full px-4 py-2 bg-surface-raised border border-ink-lighter rounded-lg text-ink-darkest focus:ring-2 focus:ring-fz-blue-light", placeholder: "E.g.: Login with valid credentials" %>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div>
              <%= f.label :given, "Given", class: "block font-semibold text-ink-darker mb-2" %>
              <%= f.text_area :given, rows: 3, class: "w-full px-4 py-2 bg-surface-raised border border-ink-lighter rounded-lg text-ink-darkest focus:ring-2 focus:ring-fz-blue-light", placeholder: "E.g.: the user is on the login page" %>
            </div>

            <div>
              <%= f.label :when_step, "When", class: "block font-semibold text-ink-darker mb-2" %>
              <%= f.text_area :when_step, rows: 3, class: "w-full px-4 py-2 bg-surface-raised border border-ink-lighter rounded-lg text-ink-darkest focus:ring-2 focus:ring-fz-blue-light", placeholder: "E.g.: they enter valid credentials" %>
            </div>

            <div>
              <%= f.label :then_step, "Then", class: "block font-semibold text-ink-darker mb-2" %>
              <%= f.text_area :then_step, rows: 3, class: "w-full px-4 py-2 bg-surface-raised border border-ink-lighter rounded-lg text-ink-darkest focus:ring-2 focus:ring-fz-blue-light", placeholder: "E.g.: they should be redirected" %>
            </div>
          </div>

          <div>
            <%= f.label :evidence_files, "Evidence (images/files)", class: "block font-semibold text-ink-darker mb-2" %>
            <label class="cursor-pointer inline-block bg-fz-blue-dark hover:bg-fz-blue-darker text-white font-semibold px-6 py-3 rounded-lg transition">
              📎 Upload Evidence
              <%= f.file_field :evidence_files, multiple: true, accept: "image/*,.pdf", class: "hidden", id: "file-upload" %>
            </label>
            <p class="text-sm text-ink-medium mt-2" id="file-count">No file selected</p>
          </div>

          <button type="submit" class="bg-fz-blue-dark hover:bg-fz-blue-darker text-white font-semibold px-5 py-2.5 rounded-lg cursor-pointer transition flex items-center gap-2" data-controller="keyboard-shortcut" data-keyboard-shortcut-key-value="c">
            + Add Scenario
            <span class="bg-white/20 text-white text-xs font-bold px-1.5 py-0.5 rounded">C</span>
          </button>
        <% end %>
      </div>
    <% end %>

    <!-- Scenario List -->
    <div class="space-y-6" id="scenarios-container" data-scenario-target="container" data-controller="sortable" data-sortable-url-value="<%= test_plan_scenario_order_path(@test_plan) %>">
      <% @test_scenarios.each do |scenario| %>
        <div class="bg-surface rounded-xl shadow-lg p-6 scenario-card" data-scenario-id="<%= scenario.id %>" data-scenario-status="<%= scenario.status %>" data-sortable-target="item" draggable="true" data-action="dragstart->sortable#dragStart dragover->sortable#dragOver dragend->sortable#dragEnd touchstart->sortable#touchStart">
          <div class="flex justify-between items-start mb-4">
            <div class="flex items-center gap-3">
              <span class="cursor-grab active:cursor-grabbing text-ink-medium hover:text-ink-dark transition" title="Drag to reorder" data-drag-handle>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M7 2a2 2 0 1 0 0 4 2 2 0 0 0 0-4zM13 2a2 2 0 1 0 0 4 2 2 0 0 0 0-4zM7 8a2 2 0 1 0 0 4 2 2 0 0 0 0-4zM13 8a2 2 0 1 0 0 4 2 2 0 0 0 0-4zM7 14a2 2 0 1 0 0 4 2 2 0 0 0 0-4zM13 14a2 2 0 1 0 0 4 2 2 0 0 0 0-4z"/>
                </svg>
              </span>
              <h3 class="text-xl font-bold text-ink-darkest"><%= scenario.title %></h3>
            </div>

            <div class="flex gap-2">
              <% if scenario.status == 'approved' %>
                <div class="bg-fz-green-dark text-white px-6 py-2 rounded-lg font-semibold">
                  ✓ Approved
                </div>
              <% elsif scenario.status == 'failed' %>
                <div class="bg-fz-red-dark text-white px-6 py-2 rounded-lg font-semibold">
                  ✗ Failed
                </div>
              <% else %>
                <% if current_user_admin? || @test_plan.user == Current.user %>
                  <button data-action="click->scenario#updateStatus" data-status="approved" data-scenario-id="<%= scenario.id %>" class="bg-fz-green-dark hover:bg-fz-green-darker text-white px-4 py-2 rounded-lg font-semibold transition">
                    ✓ Approve
                  </button>
                  <button data-action="click->scenario#updateStatus" data-status="failed" data-scenario-id="<%= scenario.id %>" class="bg-fz-red-dark hover:bg-fz-red-darker text-white px-4 py-2 rounded-lg font-semibold transition">
                    ✗ Fail
                  </button>
                <% end %>
              <% end %>
              <% if current_user_admin? || @test_plan.user == Current.user %>
                <button type="button" data-action="click->scenario#toggleEdit" class="bg-surface-raised hover:bg-ink-lightest text-ink-dark px-4 py-2 rounded-lg transition cursor-pointer" title="Edit steps">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                  </svg>
                </button>
                <%= button_to test_plan_test_scenario_path(@test_plan, scenario), method: :delete, data: { turbo_confirm: 'Are you sure you want to delete this scenario?' }, class: "bg-surface-raised hover:bg-ink-lightest text-ink-dark px-4 py-2 rounded-lg transition border-0 cursor-pointer" do %>
                  🗑️
                <% end %>
              <% end %>
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
            <div class="step-box step-box-blue bg-fz-blue-darkest p-4 rounded-lg cursor-pointer" data-step="given" data-action="click->scenario#toggleEdit">
              <p class="font-semibold text-fz-blue-light mb-2">Given:</p>
              <p class="text-ink-darker break-words step-text"><%= scenario.given %></p>
            </div>

            <div class="step-box step-box-violet bg-fz-violet-darkest p-4 rounded-lg cursor-pointer" data-step="when" data-action="click->scenario#toggleEdit">
              <p class="font-semibold text-fz-violet-light mb-2">When:</p>
              <p class="text-ink-darker break-words step-text"><%= scenario.when_step %></p>
            </div>

            <div class="step-box step-box-green bg-fz-green-darkest p-4 rounded-lg cursor-pointer" data-step="then" data-action="click->scenario#toggleEdit">
              <p class="font-semibold text-fz-green-light mb-2">Then:</p>
              <p class="text-ink-darker break-words step-text"><%= scenario.then_step %></p>
            </div>
          </div>

          <!-- Evidence -->
          <% if scenario.evidence_files.attached? %>
            <div class="mt-4">
              <p class="font-semibold text-ink-darker mb-2">Evidence:</p>
              <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                <% scenario.evidence_files.each do |file| %>
                  <div class="relative group">
                    <% if file.image? %>
                      <%= image_tag file, class: "w-full h-32 object-cover rounded-lg shadow" %>
                    <% else %>
                      <div class="w-full h-32 bg-surface-raised rounded-lg flex items-center justify-center">
                        <span class="text-4xl">📄</span>
                      </div>
                    <% end %>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <!-- Export Button -->
    <% if @test_scenarios.any? %>
      <div class="mt-8 text-center">
        <%= link_to test_plan_report_path(@test_plan, format: :pdf), target: "_blank", class: "inline-block bg-fz-blue-dark hover:bg-fz-blue-darker text-white font-bold px-12 py-4 rounded-xl shadow-xl transition transform hover:scale-105" do %>
          📄 Export PDF Report
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<script>
  // Update file counter
  document.getElementById('file-upload').addEventListener('change', function(e) {
    const count = e.target.files.length;
    const text = count === 0 ? 'No file selected' :
                 count === 1 ? '1 file selected' :
                 `${count} files selected`;
    document.getElementById('file-count').textContent = text;
  });
</script>
