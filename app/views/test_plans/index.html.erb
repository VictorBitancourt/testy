<div class="page">
  <div class="page__container">
    <div class="page__header">
      <div class="flex items-center gap-3">
        <%= link_to new_test_plan_path, class: "btn btn--primary", data: { controller: "keyboard-shortcut", keyboard_shortcut_key_value: "n" } do %>
          <%= t('test_plans.index.new_plan') %>
          <span class="kbd">N</span>
        <% end %>
      </div>
      <p class="page__stats">
        <%= t('test_plans.index.plans_count', count: TestPlan.count) %> ·
        <%= t('test_plans.index.approved_count', count: TestPlan.approved_plans.count) %> ·
        <%= t('test_plans.index.in_progress_count', count: TestPlan.in_progress.count) %> ·
        <%= t('test_plans.index.failed_count', count: TestPlan.failed_plans.count) %>
      </p>
      <div class="flex items-center gap-3">
        <%= link_to bugs_path, class: "btn btn--primary", data: { controller: "keyboard-shortcut", keyboard_shortcut_key_value: "b" } do %>
          <%= icon_tag("bug") %>
          Bug Jar
          <span class="kbd">B</span>
        <% end %>
      </div>
    </div>

    <%# === Filter Bar === %>
    <div class="filter-bar">
      <div class="filter-bar__row">
        <%= form_tag test_plans_path, method: :get, class: "filter-bar__search" do %>
          <% if params[:status].present? %>
            <input type="hidden" name="status" value="<%= params[:status] %>">
          <% end %>
          <% if params[:date_from].present? %>
            <input type="hidden" name="date_from" value="<%= params[:date_from] %>">
          <% end %>
          <% if params[:date_until].present? %>
            <input type="hidden" name="date_until" value="<%= params[:date_until] %>">
          <% end %>
          <input type="text" name="search" value="<%= @search %>" placeholder="<%= t('test_plans.index.search_placeholder') %>" class="input input--sm input--search">
          <button type="submit" class="btn btn--primary btn--sm">
            <%= t('test_plans.index.search') %>
          </button>
        <% end %>

        <span class="filter-bar__label"><%= t('test_plans.index.status_label') %></span>
        <%
          status_options = [
            { value: nil,            label: t('test_plans.index.status_all'),          active: "filter-pill--active-default",  inactive: "filter-pill--inactive" },
            { value: "approved",     label: t('test_plans.index.status_approved'),     active: "filter-pill--active-green",    inactive: "filter-pill--inactive-green" },
            { value: "failed",       label: t('test_plans.index.status_failed'),       active: "filter-pill--active-red",      inactive: "filter-pill--inactive-red" },
            { value: "in_progress",  label: t('test_plans.index.status_in_progress'),  active: "filter-pill--active-yellow",   inactive: "filter-pill--inactive-yellow" },
            { value: "not_started",  label: t('test_plans.index.status_not_started'),  active: "filter-pill--active-blue",     inactive: "filter-pill--inactive-blue" },
          ]
          current_status = params[:status]
        %>
        <% status_options.each do |opt| %>
          <% is_active = (opt[:value] == current_status) || (opt[:value].nil? && current_status.blank?) %>
          <%= form_tag test_plans_path, method: :get, class: "inline" do %>
            <% if opt[:value].present? %>
              <input type="hidden" name="status" value="<%= opt[:value] %>">
            <% end %>
            <% if params[:date_from].present? %>
              <input type="hidden" name="date_from" value="<%= params[:date_from] %>">
            <% end %>
            <% if params[:date_until].present? %>
              <input type="hidden" name="date_until" value="<%= params[:date_until] %>">
            <% end %>
            <% if @search.present? %>
              <input type="hidden" name="search" value="<%= @search %>">
            <% end %>
            <button type="submit" class="filter-pill <%= is_active ? "filter-pill--active #{opt[:active]}" : opt[:inactive] %>">
              <%= opt[:label] %>
            </button>
          <% end %>
        <% end %>
      </div>

      <% # Date filters %>
      <%= form_tag test_plans_path, method: :get, class: "filter-bar__date-row" do %>
        <% if params[:status].present? %>
          <input type="hidden" name="status" value="<%= params[:status] %>">
        <% end %>
        <% if @search.present? %>
          <input type="hidden" name="search" value="<%= @search %>">
        <% end %>
        <div>
          <label for="date_from" class="filter-bar__date-label"><%= t('test_plans.index.date_from') %></label>
          <input type="date" name="date_from" id="date_from" value="<%= params[:date_from] %>" class="input input--sm">
        </div>
        <div>
          <label for="date_until" class="filter-bar__date-label"><%= t('test_plans.index.date_to') %></label>
          <input type="date" name="date_until" id="date_until" value="<%= params[:date_until] %>" class="input input--sm">
        </div>
        <button type="submit" class="btn btn--primary btn--sm">
          <%= t('test_plans.index.filter_by_date') %>
        </button>
        <% if @filters_active %>
          <%= link_to t('test_plans.index.clear_filters'), test_plans_path, class: "filter-bar__clear" %>
        <% end %>
      <% end %>
    </div>

    <% if @test_plans.any? %>
      <div class="table-container">
        <table class="table">
          <thead>
            <tr>
              <th><%= t('test_plans.index.th_name') %></th>
              <th><%= t('test_plans.index.th_qa') %></th>
              <th><%= t('test_plans.index.th_created_by') %></th>
              <th class="text-center"><%= t('test_plans.index.th_scenarios') %></th>
              <th class="text-center"><%= t('test_plans.index.th_status') %></th>
              <th class="text-center"><%= t('test_plans.index.th_tags') %></th>
              <th><%= t('test_plans.index.th_date') %></th>
              <th class="text-center"><%= t('test_plans.index.th_actions') %></th>
            </tr>
          </thead>
          <tbody>
            <% @test_plans.each do |plan| %>
              <% status = plan.derived_status %>
              <tr>
                <td>
                  <%= link_to plan.name, plan, class: "link link--blue" %>
                </td>
                <td><%= plan.qa_name %></td>
                <td><%= plan.user&.username || "—" %></td>
                <td class="text-center">
                  <span class="txt-green-medium font-semibold"><%= plan.approved_scenarios %></span>/<%= plan.total_scenarios %>
                </td>
                <td class="text-center">
                  <% case status %>
                  <% when "approved" %>
                    <span class="<%= badge_classes(:approved) %>"><%= t('test_plans.index.status_approved').upcase %></span>
                  <% when "failed" %>
                    <span class="<%= badge_classes(:failed) %>"><%= t('test_plans.index.status_failed').upcase %></span>
                  <% when "in_progress" %>
                    <span class="<%= badge_classes(:in_progress) %>"><%= t('test_plans.index.status_in_progress').upcase %></span>
                  <% when "not_started" %>
                    <span class="<%= badge_classes(:not_started) %>"><%= t('test_plans.index.status_not_started').upcase %></span>
                  <% end %>
                </td>
                <td class="text-center">
                  <div class="flex flex-wrap justify-center gap-1">
                    <% plan.tags.each do |tag| %>
                      <%= link_to tag.name, test_plans_path(search: tag.name), class: tag_classes(:violet) %>
                    <% end %>
                  </div>
                </td>
                <td class="whitespace-nowrap">
                  <%= l(plan.created_at.to_date, format: :short_date) %>
                </td>
                <td class="text-center">
                  <div class="table__actions">
                    <%= link_to plan, class: "icon-action icon-action--view", title: t('test_plans.index.view') do %>
                      <%= icon_tag("eye") %>
                    <% end %>
                    <% if current_user_admin? || plan.user == Current.user %>
                      <%= link_to edit_test_plan_path(plan), class: "icon-action icon-action--edit", title: t('test_plans.index.edit') do %>
                        <%= icon_tag("pencil") %>
                      <% end %>
                      <%= link_to test_plan_path(plan), data: { turbo_method: :delete, turbo_confirm: t('test_plans.index.confirm_remove_plan') }, class: "icon-action icon-action--delete", title: t('test_plans.index.remove') do %>
                        <%= icon_tag("trash") %>
                      <% end %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <% if @pagy.pages > 1 %>
        <div class="mt-6 flex justify-center">
          <%== @pagy.series_nav %>
        </div>
      <% end %>
    <% else %>
      <div class="blank-slate">
        <% if @filters_active %>
          <span class="blank-slate__emoji">&#128270;</span>
          <p class="blank-slate__text"><%= t('test_plans.index.no_plans_filtered') %></p>
          <%= link_to t('test_plans.index.clear_filters'), test_plans_path, class: "btn btn--primary btn--lg" %>
        <% else %>
          <span class="blank-slate__emoji">&#128203;</span>
          <p class="blank-slate__text"><%= t('test_plans.index.no_plans_yet') %></p>
          <%= link_to new_test_plan_path, class: "btn btn--primary btn--lg" do %>
            <%= t('test_plans.index.create_first_plan') %>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
