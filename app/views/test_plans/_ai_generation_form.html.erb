<div class="panel mb-8" data-controller="ai-generate" data-ai-generate-plan-id-value="<%= test_plan.id %>">
  <h2 class="panel__title flex items-center gap-2">
    <%= icon_tag("sparkle", size: :lg, class: "txt-violet-light") %>
    <%= t('test_plans.show.generate_with_ai') %>
  </h2>

  <div class="form-stack">
    <div>
      <label class="label"><%= t('test_plans.show.feature_description') %></label>
      <textarea data-ai-generate-target="prompt" rows="3" class="input input--focus-violet" placeholder="<%= t('test_plans.show.ai_placeholder') %>"></textarea>
    </div>

    <div class="flex items-center gap-4">
      <button data-ai-generate-target="button" data-action="click->ai-generate#generate" class="btn btn--ai">
        <%= icon_tag("sparkle") %>
        <%= t('test_plans.show.generate_with_ai') %>
      </button>

      <div data-ai-generate-target="spinner" class="hidden flex items-center gap-2 txt-ink-medium">
        <%= icon_tag("spinner", class: "animate-spin") %>
        <%= t('test_plans.show.generating') %>
      </div>

      <p data-ai-generate-target="result" class="hidden txt-green-medium font-semibold"></p>
    </div>
  </div>
</div>
