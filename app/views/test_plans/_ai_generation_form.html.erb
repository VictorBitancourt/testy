<div class="bg-surface rounded-xl shadow-lg p-6 mb-8" data-controller="ai-generate" data-ai-generate-plan-id-value="<%= test_plan.id %>">
  <h2 class="text-xl font-bold text-ink-darkest mb-4 flex items-center gap-2">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-fz-violet-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" />
    </svg>
    <%= t('test_plans.show.generate_with_ai') %>
  </h2>

  <div class="space-y-4">
    <div>
      <label class="block font-semibold text-ink-darker mb-2"><%= t('test_plans.show.feature_description') %></label>
      <textarea data-ai-generate-target="prompt" rows="3" class="w-full px-4 py-2 bg-surface-raised border border-ink-lighter rounded-lg text-ink-darkest focus:ring-2 focus:ring-fz-violet-light" placeholder="<%= t('test_plans.show.ai_placeholder') %>"></textarea>
    </div>

    <div class="flex items-center gap-4">
      <button data-ai-generate-target="button" data-action="click->ai-generate#generate" class="bg-fz-violet-dark hover:bg-fz-violet-darker text-white font-semibold px-5 py-2.5 rounded-lg cursor-pointer transition flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" />
        </svg>
        <%= t('test_plans.show.generate_with_ai') %>
      </button>

      <div data-ai-generate-target="spinner" class="hidden flex items-center gap-2 text-ink-medium">
        <svg class="animate-spin h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
        </svg>
        <%= t('test_plans.show.generating') %>
      </div>

      <p data-ai-generate-target="result" class="hidden text-fz-green-dark font-semibold"></p>
    </div>
  </div>
</div>
