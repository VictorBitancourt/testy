<div class="scenario-card" data-scenario-id="<%= scenario.id %>" data-scenario-status="<%= scenario.status %>" data-sortable-target="item" draggable="true" data-action="dragstart->sortable#dragStart dragover->sortable#dragOver dragend->sortable#dragEnd touchstart->sortable#touchStart">
  <div class="scenario-card__header">
    <div class="scenario-card__title">
      <span class="drag-handle" title="<%= t('test_plans.show.drag_reorder') %>" data-drag-handle>
        <%= icon_tag("drag-handle") %>
      </span>
      <h3><%= scenario.title %></h3>
    </div>

    <div class="scenario-card__actions">
      <% if scenario.status == 'approved' %>
        <% if current_user_admin? || test_plan.user == Current.user %>
          <button data-action="click->scenario#resetStatus" data-scenario-id="<%= scenario.id %>" class="scenario-btn scenario-btn--approved" title="<%= t('test_plans.show.click_to_change') %>">
            &#10003; <%= t('test_plans.show.approved') %>
          </button>
        <% else %>
          <div class="scenario-btn scenario-btn--approved">
            &#10003; <%= t('test_plans.show.approved') %>
          </div>
        <% end %>
      <% elsif scenario.status == 'failed' %>
        <% if current_user_admin? || test_plan.user == Current.user %>
          <button data-action="click->scenario#resetStatus" data-scenario-id="<%= scenario.id %>" class="scenario-btn scenario-btn--failed" title="<%= t('test_plans.show.click_to_change') %>">
            &#10007; <%= t('test_plans.show.failed') %>
          </button>
        <% else %>
          <div class="scenario-btn scenario-btn--failed">
            &#10007; <%= t('test_plans.show.failed') %>
          </div>
        <% end %>
      <% else %>
        <% if current_user_admin? || test_plan.user == Current.user %>
          <button data-action="click->scenario#updateStatus" data-status="approved" data-scenario-id="<%= scenario.id %>" class="scenario-btn scenario-btn--approved">
            &#10003; <%= t('test_plans.show.approve') %>
          </button>
          <button data-action="click->scenario#updateStatus" data-status="failed" data-scenario-id="<%= scenario.id %>" class="scenario-btn scenario-btn--failed">
            &#10007; <%= t('test_plans.show.fail') %>
          </button>
        <% end %>
      <% end %>
      <% if current_user_admin? || test_plan.user == Current.user %>
        <button type="button" data-action="click->scenario#toggleEdit" class="scenario-btn scenario-btn--edit" title="<%= t('test_plans.index.edit') %>">
          <%= icon_tag("pencil") %>
        </button>
        <%= button_to test_plan_test_scenario_path(test_plan, scenario), method: :delete, data: { turbo_confirm: t('test_plans.show.confirm_delete_scenario') }, class: "scenario-btn scenario-btn--delete" do %>
          &#128465;&#65039;
        <% end %>
      <% end %>
    </div>
  </div>

  <div class="scenario-card__steps">
    <div class="step-box step-box--blue" data-step="given" data-action="click->scenario#toggleEdit">
      <p class="step-box__label"><%= t('test_plans.show.given') %>:</p>
      <p class="step-box__text step-text"><%= scenario.given %></p>
    </div>

    <div class="step-box step-box--violet" data-step="when" data-action="click->scenario#toggleEdit">
      <p class="step-box__label"><%= t('test_plans.show.when') %>:</p>
      <p class="step-box__text step-text"><%= scenario.when_step %></p>
    </div>

    <div class="step-box step-box--green" data-step="then" data-action="click->scenario#toggleEdit">
      <p class="step-box__label"><%= t('test_plans.show.then') %>:</p>
      <p class="step-box__text step-text"><%= scenario.then_step %></p>
    </div>
  </div>

  <% if scenario.evidence_files.attached? %>
    <div class="mt-4">
      <p class="font-semibold txt-ink-darker mb-2"><%= t('test_plans.show.evidence') %></p>
      <div class="evidence-grid">
        <% scenario.evidence_files.each do |file| %>
          <div class="evidence-item">
            <% if file.image? %>
              <%= image_tag file %>
            <% else %>
              <div class="evidence-placeholder">
                <span>&#128196;</span>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <div class="bug-association-container mt-4" data-scenario-id="<%= scenario.id %>">
    <% if scenario.bug.present? %>
      <div class="bug-link">
        <%= icon_tag("bug", size: :sm, class: "txt-red-light") %>
        <%= link_to scenario.bug.display_name, bug_path(scenario.bug), class: "bug-link__name" %>
        <% if current_user_admin? || test_plan.user == Current.user %>
          <button type="button" data-action="click->scenario#removeBug" data-scenario-id="<%= scenario.id %>" class="bug-link__remove">&#10005;</button>
        <% end %>
      </div>
    <% elsif scenario.status == 'failed' && (current_user_admin? || test_plan.user == Current.user) %>
      <button type="button" data-action="click->scenario#showBugSearch" data-scenario-id="<%= scenario.id %>" class="bug-associate-btn">
        <%= icon_tag("bug", size: :sm) %> <%= t('test_plans.show.associate_bug') %>
      </button>
    <% end %>
  </div>
</div>
