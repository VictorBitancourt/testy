<div class="page--centered">
  <div class="page__container--xs">
    <div class="text-center mb-8">
      <svg width="120" height="120" viewBox="0 0 220 220" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <linearGradient id="login-grad" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" style="stop-color:#f093fb"/>
            <stop offset="100%" style="stop-color:#f5576c"/>
          </linearGradient>
        </defs>
        <rect x="30" y="30" width="160" height="160" rx="20" fill="none" stroke="url(#login-grad)" stroke-width="8" transform="rotate(-5 110 110)"/>
        <path d="M 75 110 L 95 130 L 145 80" stroke="url(#login-grad)" stroke-width="12" stroke-linecap="round" stroke-linejoin="round" fill="none" transform="rotate(-5 110 110)"/>
        <text x="110" y="175" font-family="Arial Black, Arial" font-size="32" font-weight="900" fill="url(#login-grad)" text-anchor="middle" transform="rotate(-5 110 175)">testy</text>
      </svg>
    </div>

    <div class="panel panel--padded panel--bordered">
      <h1 class="panel__title--center text-2xl font-bold"><%= t('sessions.new.sign_in') %></h1>

      <%= form_with url: session_path, method: :post, class: "form-stack" do |f| %>
        <div>
          <label for="username" class="label--sm"><%= t('sessions.new.username') %></label>
          <input type="text" name="username" id="username" autocomplete="username" autofocus required class="input" />
        </div>

        <div>
          <label for="password" class="label--sm"><%= t('sessions.new.password') %></label>
          <input type="password" name="password" id="password" autocomplete="current-password" required class="input" />
        </div>

        <button type="submit" class="btn btn--primary full-width">
          <%= t('sessions.new.sign_in') %>
        </button>
      <% end %>

      <div class="lang-switcher mt-4">
        <%= button_to locale_path(locale: :en), method: :patch, class: "lang-btn #{I18n.locale == :en ? 'lang-btn--active' : 'lang-btn--inactive'}" do %>
          <%= t('language.en') %>
        <% end %>
        <%= button_to locale_path(locale: :'pt-BR'), method: :patch, class: "lang-btn #{I18n.locale == :'pt-BR' ? 'lang-btn--active' : 'lang-btn--inactive'}" do %>
          <%= t('language.pt_br') %>
        <% end %>
      </div>
    </div>
  </div>
</div>
