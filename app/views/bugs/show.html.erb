<div class="page">
  <div class="page__container--md">
    <div class="mb-4">
      <%= link_to bugs_path, class: "page__back", data: { controller: "keyboard-shortcut", keyboard_shortcut_key_value: "b" } do %>
        &larr; <%= t('bugs.show.back') %>
        <span class="kbd">B</span>
      <% end %>
    </div>

    <div class="panel mb-6 relative">
      <% if @bug.resolved? %>
        <div class="stamp">
          <div class="stamp__inner">
            <div class="stamp__title"><%= t('bugs.show.resolved_stamp') %></div>
            <div class="stamp__date"><%= l(Date.today, format: :short_date).upcase %></div>
            <div class="stamp__by">by <%= @bug.user&.username %></div>
          </div>
        </div>
      <% end %>

      <div class="flex items-start justify-between">
        <div>
          <h1 class="text-3xl font-black mb-2">
            <span class="txt-ink-medium font-mono">#<%= @bug.id %></span> - <%= @bug.title %>
          </h1>
          <p class="txt-ink-medium text-sm">
            <%= t('bugs.show.reported_by') %> <span class="font-semibold txt-ink-dark"><%= @bug.user&.username || "—" %></span>
            · <%= l(@bug.created_at.to_date, format: :short_date) %>
          </p>
        </div>
        <div>
          <% if @bug.open? %>
            <span class="<%= badge_classes(:open) %>"><%= t('bugs.show.status_open') %></span>
          <% else %>
            <span class="<%= badge_classes(:resolved) %>"><%= t('bugs.show.status_resolved') %></span>
          <% end %>
        </div>
      </div>

      <% if @bug.feature_tag.present? || @bug.cause_tag.present? %>
        <div class="flex flex-wrap gap-2 mt-4">
          <% if @bug.feature_tag.present? %>
            <%= link_to bugs_path(feature_tag: @bug.feature_tag), class: tag_classes(:blue) do %>
              <%= t('bugs.show.feature_label') %> <%= @bug.feature_tag %>
            <% end %>
          <% end %>
          <% if @bug.cause_tag.present? %>
            <%= link_to bugs_path(cause_tag: @bug.cause_tag), class: tag_classes(:red) do %>
              <%= t('bugs.show.cause_label') %> <%= @bug.cause_tag %>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>

    <div class="panel mb-6">
      <h2 class="text-lg font-bold mb-3"><%= t('bugs.show.description') %></h2>
      <div class="txt-ink-dark whitespace-pre-wrap"><%= @bug.description %></div>
    </div>

    <% if @bug.steps_to_reproduce.present? || @bug.obtained_result.present? || @bug.expected_result.present? %>
      <div class="panel mb-6 stack--lg">
        <% if @bug.steps_to_reproduce.present? %>
          <div>
            <h3 class="font-bold mb-2"><%= t('bugs.show.steps_to_reproduce') %></h3>
            <div class="txt-ink-dark whitespace-pre-wrap"><%= @bug.steps_to_reproduce %></div>
          </div>
        <% end %>

        <% if @bug.obtained_result.present? %>
          <div>
            <h3 class="font-bold txt-red-light mb-2"><%= t('bugs.show.obtained_result') %></h3>
            <div class="txt-ink-dark whitespace-pre-wrap"><%= @bug.obtained_result %></div>
          </div>
        <% end %>

        <% if @bug.expected_result.present? %>
          <div>
            <h3 class="font-bold txt-green-light mb-2"><%= t('bugs.show.expected_result') %></h3>
            <div class="txt-ink-dark whitespace-pre-wrap"><%= @bug.expected_result %></div>
          </div>
        <% end %>
      </div>
    <% end %>

    <% if @bug.evidence_files.attached? %>
      <div class="panel mb-6">
        <h2 class="text-lg font-bold mb-3"><%= t('bugs.show.evidence') %></h2>
        <div class="evidence-grid">
          <% @bug.evidence_files.each do |file| %>
            <div class="evidence-item">
              <% if file.image? %>
                <%= image_tag file %>
              <% else %>
                <div class="evidence-placeholder">
                  <span>&#128196;</span>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <% if @bug.test_scenarios.any? %>
      <div class="panel mb-6">
        <h2 class="text-lg font-bold mb-3"><%= t('bugs.show.associated_scenarios') %></h2>
        <div class="stack--sm">
          <% @bug.test_scenarios.includes(:test_plan).each do |scenario| %>
            <div class="flex items-center justify-between" style="background:var(--color-surface-raised);border-radius:var(--radius-lg);padding:0.75rem 1rem;">
              <div>
                <span class="font-semibold"><%= scenario.title %></span>
                <span class="text-sm txt-ink-medium" style="margin-left:var(--space-2);">
                  (<%= link_to scenario.test_plan.name, test_plan_path(scenario.test_plan), class: "link link--blue" %>)
                </span>
              </div>
              <% if scenario.status == "approved" %>
                <span class="<%= badge_classes(:approved) %>"><%= t('bugs.show.scenario_approved') %></span>
              <% elsif scenario.status == "failed" %>
                <span class="<%= badge_classes(:failed) %>"><%= t('bugs.show.scenario_failed') %></span>
              <% else %>
                <span class="<%= badge_classes(:in_progress) %>"><%= t('bugs.show.scenario_pending') %></span>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <div class="flex flex-wrap items-center gap-4">
      <% if current_user_admin? || @bug.user == Current.user %>
        <% if @bug.open? %>
          <%= button_to bug_path(@bug), method: :patch, params: { bug: { status: "resolved" } }, class: "btn btn--success btn--lg" do %>
            &#10003; <%= t('bugs.show.resolve') %>
          <% end %>
        <% else %>
          <%= button_to bug_path(@bug), method: :patch, params: { bug: { status: "open" } }, class: "btn btn--warning btn--lg" do %>
            &#8634; <%= t('bugs.show.reopen') %>
          <% end %>
        <% end %>

        <%= link_to edit_bug_path(@bug), class: "btn btn--primary btn--lg" do %>
          &#9998; <%= t('bugs.show.edit') %>
        <% end %>

        <%= button_to bug_path(@bug), method: :delete, data: { turbo_confirm: t('bugs.show.confirm_delete') }, class: "btn btn--danger btn--lg" do %>
          &#128465;&#65039; <%= t('bugs.show.delete') %>
        <% end %>
      <% end %>

      <%= link_to bug_report_path(@bug, format: :pdf), target: "_blank", class: "btn btn--secondary btn--lg" do %>
        &#128196; <%= t('bugs.show.export_pdf') %>
      <% end %>
    </div>
  </div>
</div>
