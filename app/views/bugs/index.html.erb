<div class="page">
  <div class="page__container">
    <div class="page__header">
      <div class="flex items-center gap-3">
        <%= link_to new_bug_path, class: "btn btn--danger", data: { controller: "keyboard-shortcut", keyboard_shortcut_key_value: "n" } do %>
          <%= t('bugs.index.new_bug') %>
          <span class="kbd">N</span>
        <% end %>
      </div>
      <p class="page__stats">
        <%= t('bugs.index.bugs_count', count: Bug.count) %> ·
        <%= t('bugs.index.open_count', count: Bug.open_bugs.count) %> ·
        <%= t('bugs.index.resolved_count', count: Bug.resolved.count) %>
      </p>
      <div class="flex items-center gap-3">
        <%= link_to bug_root_causes_path, class: "btn btn--ai", data: { controller: "keyboard-shortcut", keyboard_shortcut_key_value: "r", name:"The Root Of All Evil" } do %>
          <%= icon_tag("chart-bar") %>
          <%= t('bugs.index.root_causes') %>
          <span class="kbd">R</span>
        <% end %>
        <%= link_to test_plans_path, class: "btn btn--primary", data: { controller: "keyboard-shortcut", keyboard_shortcut_key_value: "p" } do %>
          <%= t('bugs.index.test_plans') %>
          <span class="kbd">P</span>
        <% end %>
      </div>
    </div>

    <div class="filter-bar">
      <div class="filter-bar__row">
        <%= form_tag bugs_path, method: :get, class: "filter-bar__search" do %>
          <% if params[:status].present? %>
            <input type="hidden" name="status" value="<%= params[:status] %>">
          <% end %>
          <% if params[:date_from].present? %>
            <input type="hidden" name="date_from" value="<%= params[:date_from] %>">
          <% end %>
          <% if params[:date_until].present? %>
            <input type="hidden" name="date_until" value="<%= params[:date_until] %>">
          <% end %>
          <input type="text" name="search" value="<%= @search %>" placeholder="<%= t('bugs.index.search_placeholder') %>" class="input input--sm input--search">
          <button type="submit" class="btn btn--primary btn--sm">
            <%= t('bugs.index.search') %>
          </button>
        <% end %>

        <span class="filter-bar__label"><%= t('bugs.index.status_label') %></span>
        <%
          status_options = [
            { value: nil,        label: t('bugs.index.status_all'),      active: "filter-pill--active-default",  inactive: "filter-pill--inactive" },
            { value: "open",     label: t('bugs.index.status_open'),     active: "filter-pill--active-yellow",   inactive: "filter-pill--inactive-yellow" },
            { value: "resolved", label: t('bugs.index.status_resolved'), active: "filter-pill--active-green",    inactive: "filter-pill--inactive-green" },
          ]
          current_status = params[:status]
        %>
        <% status_options.each do |opt| %>
          <% is_active = (opt[:value] == current_status) || (opt[:value].nil? && current_status.blank?) %>
          <%= form_tag bugs_path, method: :get, class: "inline" do %>
            <% if opt[:value].present? %>
              <input type="hidden" name="status" value="<%= opt[:value] %>">
            <% end %>
            <% if params[:date_from].present? %>
              <input type="hidden" name="date_from" value="<%= params[:date_from] %>">
            <% end %>
            <% if params[:date_until].present? %>
              <input type="hidden" name="date_until" value="<%= params[:date_until] %>">
            <% end %>
            <% if @search.present? %>
              <input type="hidden" name="search" value="<%= @search %>">
            <% end %>
            <button type="submit" class="filter-pill <%= is_active ? "filter-pill--active #{opt[:active]}" : opt[:inactive] %>">
              <%= opt[:label] %>
            </button>
          <% end %>
        <% end %>
      </div>

      <%= form_tag bugs_path, method: :get, class: "filter-bar__date-row" do %>
        <% if params[:status].present? %>
          <input type="hidden" name="status" value="<%= params[:status] %>">
        <% end %>
        <% if @search.present? %>
          <input type="hidden" name="search" value="<%= @search %>">
        <% end %>
        <div>
          <label for="date_from" class="filter-bar__date-label"><%= t('bugs.index.date_from') %></label>
          <input type="date" name="date_from" id="date_from" value="<%= params[:date_from] %>" class="input input--sm">
        </div>
        <div>
          <label for="date_until" class="filter-bar__date-label"><%= t('bugs.index.date_to') %></label>
          <input type="date" name="date_until" id="date_until" value="<%= params[:date_until] %>" class="input input--sm">
        </div>
        <button type="submit" class="btn btn--primary btn--sm">
          <%= t('bugs.index.filter_by_date') %>
        </button>
        <% if @filters_active %>
          <%= link_to t('bugs.index.clear_filters'), bugs_path, class: "filter-bar__clear" %>
        <% end %>
      <% end %>
    </div>

    <% if @bugs.any? %>
      <div class="table-container">
        <table class="table">
          <thead>
            <tr>
              <th><%= t('bugs.index.th_id') %></th>
              <th><%= t('bugs.index.th_title') %></th>
              <th><%= t('bugs.index.th_feature') %></th>
              <th><%= t('bugs.index.th_cause') %></th>
              <th class="text-center"><%= t('bugs.index.th_status') %></th>
              <th><%= t('bugs.index.th_date') %></th>
              <th class="text-center"><%= t('bugs.index.th_actions') %></th>
            </tr>
          </thead>
          <tbody>
            <% @bugs.each do |bug| %>
              <tr>
                <td class="font-mono txt-ink-medium">#<%= bug.id %></td>
                <td>
                  <%= link_to bug.title, bug, class: "link link--red" %>
                </td>
                <td>
                  <% if bug.feature_tag.present? %>
                    <%= link_to bug.feature_tag, bugs_path(feature_tag: bug.feature_tag), class: tag_classes(:blue) %>
                  <% else %>
                    <span class="txt-ink-medium">—</span>
                  <% end %>
                </td>
                <td>
                  <% if bug.cause_tag.present? %>
                    <%= link_to bug.cause_tag, bugs_path(cause_tag: bug.cause_tag), class: tag_classes(:red) %>
                  <% else %>
                    <span class="txt-ink-medium">—</span>
                  <% end %>
                </td>
                <td class="text-center">
                  <% if bug.open? %>
                    <span class="<%= badge_classes(:open) %>"><%= t('bugs.index.status_open').upcase %></span>
                  <% else %>
                    <span class="<%= badge_classes(:resolved) %>"><%= t('bugs.index.status_resolved').upcase %></span>
                  <% end %>
                </td>
                <td class="whitespace-nowrap">
                  <%= l(bug.created_at.to_date, format: :short_date) %>
                </td>
                <td class="text-center">
                  <div class="table__actions">
                    <%= link_to bug, class: "icon-action icon-action--view", title: t('bugs.index.view') do %>
                      <%= icon_tag("eye") %>
                    <% end %>
                    <% if current_user_admin? || bug.user == Current.user %>
                      <%= link_to edit_bug_path(bug), class: "icon-action icon-action--edit", title: t('bugs.index.edit') do %>
                        <%= icon_tag("pencil") %>
                      <% end %>
                      <%= link_to bug_path(bug), data: { turbo_method: :delete, turbo_confirm: t('bugs.index.confirm_remove_bug') }, class: "icon-action icon-action--delete", title: t('bugs.index.remove') do %>
                        <%= icon_tag("trash") %>
                      <% end %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <% if @pagy.pages > 1 %>
        <div class="mt-6 flex justify-center">
          <%== @pagy.series_nav %>
        </div>
      <% end %>
    <% else %>
      <div class="blank-slate">
        <% if @filters_active %>
          <span class="blank-slate__emoji">&#128270;</span>
          <p class="blank-slate__text"><%= t('bugs.index.no_bugs_filtered') %></p>
          <%= link_to t('bugs.index.clear_filters'), bugs_path, class: "btn btn--primary btn--lg" %>
        <% else %>
          <span class="blank-slate__emoji">&#128027;</span>
          <p class="blank-slate__text"><%= t('bugs.index.no_bugs_yet') %></p>
          <%= link_to new_bug_path, class: "btn btn--danger btn--lg" do %>
            <%= t('bugs.index.create_first_bug') %>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
