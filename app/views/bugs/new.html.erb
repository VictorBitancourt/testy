<div class="page">
  <div class="page__container--sm">
    <div class="mb-4">
      <%= link_to bugs_path, class: "page__back", data: { controller: "keyboard-shortcut", keyboard_shortcut_key_value: "b" } do %>
        &larr; <%= t('bugs.new.back') %>
        <span class="kbd">B</span>
      <% end %>
    </div>

    <div class="panel panel--padded">
      <h1 class="panel__title panel__title--lg"><%= t('bugs.new.title') %></h1>

      <%= render 'form', bug: @bug %>
    </div>
  </div>
</div>
