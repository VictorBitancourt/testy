<div class="page--centered">
  <div class="page__container--xs">
    <div class="flex justify-center mb-8">
      <svg width="120" height="120" viewBox="0 0 220 220" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <linearGradient id="reg-grad" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" style="stop-color:#f093fb"/>
            <stop offset="100%" style="stop-color:#f5576c"/>
          </linearGradient>
        </defs>
        <rect x="30" y="30" width="160" height="160" rx="20" fill="none" stroke="url(#reg-grad)" stroke-width="8" transform="rotate(-5 110 110)"/>
        <path d="M 75 110 L 95 130 L 145 80" stroke="url(#reg-grad)" stroke-width="12" stroke-linecap="round" stroke-linejoin="round" fill="none" transform="rotate(-5 110 110)"/>
        <text x="110" y="175" font-family="Arial Black, Arial" font-size="32" font-weight="900" fill="url(#reg-grad)" text-anchor="middle" transform="rotate(-5 110 175)">testy</text>
      </svg>
    </div>

    <div class="panel panel--padded panel--bordered">
      <h1 class="text-2xl font-bold text-center mb-2"><%= t('registrations.new.initial_setup') %></h1>
      <p class="text-sm txt-ink-dark text-center mb-6"><%= t('registrations.new.create_admin') %></p>

      <%= form_with model: @user, url: registration_path, class: "form-stack" do |f| %>
        <% if @user.errors.any? %>
          <div class="error-box--light">
            <ul>
              <% @user.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div>
          <label for="user_username" class="label--sm"><%= t('registrations.new.username') %></label>
          <%= f.text_field :username, autocomplete: "username", autofocus: true, required: true, class: "input" %>
        </div>

        <div>
          <label for="user_password" class="label--sm"><%= t('registrations.new.password') %></label>
          <%= f.password_field :password, autocomplete: "new-password", required: true, class: "input" %>
        </div>

        <div>
          <label for="user_password_confirmation" class="label--sm"><%= t('registrations.new.confirm_password') %></label>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", required: true, class: "input" %>
        </div>

        <button type="submit" class="btn btn--primary full-width">
          <%= t('registrations.new.create_user') %>
        </button>
      <% end %>

      <div class="lang-switcher mt-4">
        <%= button_to locale_path(locale: :en), method: :patch, class: "lang-btn #{I18n.locale == :en ? 'lang-btn--active' : 'lang-btn--inactive'}" do %>
          <%= t('language.en') %>
        <% end %>
        <%= button_to locale_path(locale: :'pt-BR'), method: :patch, class: "lang-btn #{I18n.locale == :'pt-BR' ? 'lang-btn--active' : 'lang-btn--inactive'}" do %>
          <%= t('language.pt_br') %>
        <% end %>
      </div>
    </div>
  </div>
</div>
