<div class="min-h-screen bg-canvas pb-12 px-4" style="padding-top: 90px;">
  <div class="max-w-4xl mx-auto">
    <!-- Back -->
    <div class="mb-4">
      <%= link_to root_path, class: "text-fz-blue-light hover:text-fz-blue-dark font-semibold inline-flex items-center gap-2", data: { controller: "keyboard-shortcut", keyboard_shortcut_key_value: "b" } do %>
        &larr; <%= t('users.index.back') %>
        <span class="bg-white/20 text-fz-blue-light text-xs font-bold px-1.5 py-0.5 rounded">B</span>
      <% end %>
    </div>

    <div class="flex justify-between items-center mb-8">
      <h1 class="text-4xl font-black text-ink-darkest"><%= t('users.index.title') %></h1>
      <%= link_to new_user_path, class: btn_classes(:primary) do %>
        <%= t('users.index.new_user') %>
      <% end %>
    </div>

    <div class="bg-surface rounded-xl shadow-lg overflow-hidden">
      <table class="w-full">
        <thead>
          <tr class="bg-surface-raised text-ink-dark text-sm uppercase tracking-wide">
            <th class="px-6 py-4 text-left font-semibold"><%= t('users.index.th_username') %></th>
            <th class="px-6 py-4 text-left font-semibold"><%= t('users.index.th_role') %></th>
            <th class="px-6 py-4 text-right font-semibold"><%= t('users.index.th_actions') %></th>
          </tr>
        </thead>
        <tbody>
          <% @users.each do |user| %>
            <tr class="border-t border-ink-lighter hover:bg-surface-raised/50 transition">
              <td class="px-6 py-4 text-ink-darkest font-medium"><%= user.username %></td>
              <td class="px-6 py-4">
                <% if user.admin? %>
                  <span class="<%= badge_classes(:admin) %>">admin</span>
                <% else %>
                  <span class="<%= badge_classes(:user) %>">user</span>
                <% end %>
              </td>
              <td class="px-6 py-4 text-right">
                <div class="flex justify-end gap-2">
                  <%= link_to edit_user_path(user), class: btn_classes(:warning, size: :sm) do %>
                    <%= t('users.index.reset_password') %>
                  <% end %>
                  <% if user != Current.user %>
                    <%= button_to user_path(user), method: :delete, data: { turbo_confirm: t('users.index.confirm_delete', username: user.username) }, class: "#{btn_classes(:danger, size: :sm)} border-0" do %>
                      <%= t('users.index.delete') %>
                    <% end %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
