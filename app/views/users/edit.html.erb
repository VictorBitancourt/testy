<div class="page--centered">
  <div class="page__container--xs">
    <div class="panel panel--padded panel--bordered">
      <h1 class="text-2xl font-bold text-center mb-2"><%= t('users.edit.title') %></h1>
      <p class="text-sm txt-ink-dark text-center mb-6"><%= t('users.edit.user_label') %> <span class="font-semibold"><%= @user.username %></span></p>

      <%= form_with model: @user, url: user_path(@user), method: :patch, class: "form-stack" do |f| %>
        <% if @user.errors.any? %>
          <div class="error-box--light">
            <ul>
              <% @user.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div>
          <label for="user_password" class="label--sm"><%= t('users.edit.new_password') %></label>
          <%= f.password_field :password, autocomplete: "new-password", required: true, class: "input" %>
        </div>

        <div>
          <label for="user_password_confirmation" class="label--sm"><%= t('users.edit.confirm_new_password') %></label>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", required: true, class: "input" %>
        </div>

        <button type="submit" class="btn btn--warning full-width">
          <%= t('users.edit.reset_password') %>
        </button>
      <% end %>

      <div class="mt-4 text-center">
        <%= link_to "&larr; #{t('users.edit.back')}".html_safe, users_path, class: "page__back text-sm" %>
      </div>
    </div>
  </div>
</div>
