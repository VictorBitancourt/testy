<div class="page--centered">
  <div class="page__container--xs">
    <div class="panel panel--padded panel--bordered">
      <h1 class="panel__title--center text-2xl font-bold"><%= t('users.new.title') %></h1>

      <%= form_with model: @user, url: users_path, class: "form-stack" do |f| %>
        <% if @user.errors.any? %>
          <div class="error-box--light">
            <ul>
              <% @user.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div>
          <label for="user_username" class="label--sm"><%= t('users.new.username') %></label>
          <%= f.text_field :username, autocomplete: "off", autofocus: true, required: true, class: "input" %>
        </div>

        <div>
          <label for="user_password" class="label--sm"><%= t('users.new.password') %></label>
          <%= f.password_field :password, autocomplete: "new-password", required: true, class: "input" %>
        </div>

        <div>
          <label for="user_password_confirmation" class="label--sm"><%= t('users.new.confirm_password') %></label>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", required: true, class: "input" %>
        </div>

        <div>
          <label for="user_role" class="label--sm"><%= t('users.new.role') %></label>
          <%= f.select :role, [[t('users.new.role_user'), "user"], [t('users.new.role_admin'), "admin"]], {}, class: "input" %>
        </div>

        <button type="submit" class="btn btn--primary full-width">
          <%= t('users.new.create_user') %>
        </button>
      <% end %>

      <div class="mt-4 text-center">
        <%= link_to "&larr; #{t('users.new.back')}".html_safe, users_path, class: "page__back text-sm" %>
      </div>
    </div>
  </div>
</div>
