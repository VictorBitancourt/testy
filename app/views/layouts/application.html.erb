<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title>Testy</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <meta name="translations" content="<%= I18n.t('javascript').to_json %>">
    <meta name="view-transition" content="same-origin">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "reset",          "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "variables",      "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "base",           "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "animations",     "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "layout",         "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "buttons",        "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "inputs",         "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "panels",         "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "tables",         "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "badges",         "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "tags",           "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "filters",        "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "flash",          "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "blank-slates",   "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "cards",          "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "dropdown",       "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "confirm-dialog", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "pagy",           "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "utilities",      "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application",    "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% if authenticated? %>
      <div class="topbar">
        <div data-controller="dropdown" class="dropdown">
          <button data-action="click->dropdown#toggle" class="dropdown__trigger">
            <%= image_tag "testy-logo.png", alt: "testy", style: "height:68px;width:68px;object-fit:contain;", data: { controller: "easter-egg", action: "click->easter-egg#click" } %>
            <span class="kbd">T</span>
            <%= icon_tag("chevron-down", size: :sm, class: "txt-ink-medium") %>
          </button>

          <div data-dropdown-target="menu" class="hidden dropdown__menu">
            <div class="dropdown__user">
              <p class="dropdown__user-name"><%= Current.user.username %></p>
              <% if current_user_admin? %>
                <span class="dropdown__user-role--admin">admin</span>
              <% else %>
                <span class="dropdown__user-role--user">user</span>
              <% end %>
            </div>

            <hr class="dropdown__divider">

            <div class="dropdown__items">
              <%= link_to test_plans_path, class: "dropdown__item" do %>
                <%= icon_tag("test-plans", class: "txt-ink-medium") %>
                <%= t('layouts.nav.test_plans') %>
              <% end %>

              <%= link_to bugs_path, class: "dropdown__item" do %>
                <%= icon_tag("bug", class: "txt-ink-medium") %>
                <%= t('layouts.nav.bug_jar') %>
              <% end %>

              <% if current_user_admin? %>
                <%= link_to users_path, class: "dropdown__item" do %>
                  <%= icon_tag("users", class: "txt-ink-medium") %>
                  <%= t('layouts.nav.users') %>
                <% end %>
              <% end %>
            </div>

            <hr class="dropdown__divider">

            <div class="lang-switcher">
              <%= button_to locale_path(locale: :en), method: :patch, class: "lang-btn #{I18n.locale == :en ? 'lang-btn--active' : 'lang-btn--inactive'}" do %>
                <%= t('language.en') %>
              <% end %>
              <%= button_to locale_path(locale: :'pt-BR'), method: :patch, class: "lang-btn #{I18n.locale == :'pt-BR' ? 'lang-btn--active' : 'lang-btn--inactive'}" do %>
                <%= t('language.pt_br') %>
              <% end %>
            </div>

            <hr class="dropdown__divider">

            <div style="padding-top: var(--space-2);">
              <%= button_to session_path, method: :delete, class: "dropdown__item dropdown__item--danger" do %>
                <%= icon_tag("sign-out") %>
                <%= t('layouts.nav.sign_out') %>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <% if notice %>
      <div class="flash flash--notice" data-controller="flash">
        <div class="flash__inner"><%= notice %></div>
      </div>
    <% end %>

    <% if alert %>
      <div class="flash flash--alert" data-controller="flash">
        <div class="flash__inner"><%= alert %></div>
      </div>
    <% end %>

    <%= yield %>
  </body>
</html>
