<!DOCTYPE html>
<html>
  <head>
    <title>Testy</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-canvas text-ink-darkest">
    <% if authenticated? %>
      <div class="absolute top-0 left-0 right-0 z-50 flex justify-center pt-3 pointer-events-none">
        <div data-controller="dropdown" class="relative pointer-events-auto">
          <button data-action="click->dropdown#toggle" class="flex items-center gap-2 px-2 py-1 rounded-lg transition group cursor-pointer">
            <%= image_tag "testy-logo.png", alt: "testy", style: "height:68px;width:68px;", class: "object-contain", data: { controller: "easter-egg", action: "click->easter-egg#click" } %>
            <span class="bg-white/20 text-ink-dark text-xs font-bold px-1.5 py-0.5 rounded">T</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-ink-medium" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>

          <div data-dropdown-target="menu" class="hidden absolute top-full left-1/2 -translate-x-1/2 mt-2 w-72 p-3" style="background: oklch(24% 0.022 232); border-radius: 18px; box-shadow: 0 0 0 1px oklch(40% 0.026 262 / 0.45), 0 0 24px oklch(57.02% 0.1895 260.46 / 0.12), 0 12px 40px oklch(0% 0 0 / 0.5);">
            <!-- User info -->
            <div class="px-3 pt-2" style="padding-bottom: 14px;">
              <p class="text-base font-semibold text-ink-darkest"><%= Current.user.username %></p>
              <% if current_user_admin? %>
                <span class="text-sm text-fz-violet-light font-medium">admin</span>
              <% else %>
                <span class="text-sm text-fz-blue-light font-medium">user</span>
              <% end %>
            </div>

            <hr class="mx-6 border-0" style="height: 1px; background: oklch(40% 0.026 262 / 0.45);">

            <!-- Menu items -->
            <div class="py-2">
              <%= link_to test_plans_path, class: "flex items-center gap-3 px-3 py-2.5 text-sm text-ink-dark hover:text-ink-darkest hover:bg-white/5 rounded-xl transition" do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-ink-medium" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
                </svg>
                Test Plans
              <% end %>

              <% if current_user_admin? %>
                <%= link_to users_path, class: "flex items-center gap-3 px-3 py-2.5 text-sm text-ink-dark hover:text-ink-darkest hover:bg-white/5 rounded-xl transition" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-ink-medium" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
                  </svg>
                  Users
                <% end %>
              <% end %>
            </div>

            <hr class="mx-6 border-0" style="height: 1px; background: oklch(40% 0.026 262 / 0.45);">

            <div class="pt-2">
              <%= button_to session_path, method: :delete, class: "w-full flex items-center gap-3 px-3 py-2.5 text-sm text-fz-red-light hover:bg-white/5 rounded-xl transition text-left cursor-pointer" do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15m3 0l3-3m0 0l-3-3m3 3H9" />
                </svg>
                Sign Out
              <% end %>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <% if notice %>
      <div class="flash-message fixed top-4 right-4 bg-fz-green-dark text-white px-6 py-3 rounded-lg shadow-lg z-50 animate-fade-in">
        <%= notice %>
      </div>
    <% end %>

    <% if alert %>
      <div class="flash-message fixed top-4 right-4 bg-fz-red-dark text-white px-6 py-3 rounded-lg shadow-lg z-50 animate-fade-in">
        <%= alert %>
      </div>
    <% end %>

    <%= yield %>

    <script>
      // Auto-hide flash messages after 4 seconds
      document.addEventListener('DOMContentLoaded', function() {
        const flashMessages = document.querySelectorAll('.flash-message');
        
        flashMessages.forEach(function(message) {
          setTimeout(function() {
            // Add fade out transition
            message.style.transition = 'opacity 0.5s ease-out, transform 0.5s ease-out';
            message.style.opacity = '0';
            message.style.transform = 'translateX(100px)';
            
            // Remove the element after animation
            setTimeout(function() {
              message.remove();
            }, 500);
          }, 4000); // 4 seconds
        });
      });

      // Also works with Turbo (for Rails SPA navigation)
      document.addEventListener('turbo:load', function() {
        const flashMessages = document.querySelectorAll('.flash-message');
        
        flashMessages.forEach(function(message) {
          setTimeout(function() {
            message.style.transition = 'opacity 0.5s ease-out, transform 0.5s ease-out';
            message.style.opacity = '0';
            message.style.transform = 'translateX(100px)';
            
            setTimeout(function() {
              message.remove();
            }, 500);
          }, 4000);
        });
      });
    </script>
  </body>
</html>