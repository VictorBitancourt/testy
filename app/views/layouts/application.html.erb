<!DOCTYPE html>
<html>
  <head>
    <title>Testy</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-canvas text-ink-darkest">
    <% if authenticated? %>
      <div class="absolute top-0 left-0 right-0 z-50 flex justify-center pt-3 pointer-events-none">
        <div data-controller="dropdown" class="relative pointer-events-auto">
          <button data-action="click->dropdown#toggle" class="flex items-center gap-2 px-2 py-1 rounded-lg transition group cursor-pointer">
            <%= image_tag "testy-logo.png", alt: "testy", style: "height:95px;width:95px;", class: "object-contain" %>
            <span class="bg-white/20 text-ink-dark text-xs font-bold px-1.5 py-0.5 rounded">T</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-ink-medium" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>

          <div data-dropdown-target="menu" class="hidden absolute top-full left-1/2 -translate-x-1/2 mt-2 w-56 bg-surface border border-ink-lighter rounded-xl shadow-xl overflow-hidden">
            <div class="px-4 py-3 border-b border-ink-lighter/50">
              <p class="text-sm font-semibold text-ink-darkest"><%= Current.user.username %></p>
              <% if current_user_admin? %>
                <span class="text-xs text-fz-violet-light font-semibold">admin</span>
              <% else %>
                <span class="text-xs text-fz-blue-light font-semibold">user</span>
              <% end %>
            </div>

            <div class="py-1">
              <%= link_to test_plans_path, class: "flex items-center gap-3 px-4 py-2.5 text-sm text-ink-dark hover:bg-surface-raised transition" do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-ink-medium" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0h4" />
                </svg>
                Planos de Teste
              <% end %>

              <% if current_user_admin? %>
                <%= link_to users_path, class: "flex items-center gap-3 px-4 py-2.5 text-sm text-ink-dark hover:bg-surface-raised transition" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-ink-medium" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                  </svg>
                  Usuarios
                <% end %>
              <% end %>
            </div>

            <div class="border-t border-ink-lighter/50 py-1">
              <%= button_to session_path, method: :delete, class: "w-full flex items-center gap-3 px-4 py-2.5 text-sm text-fz-red-light hover:bg-surface-raised transition text-left" do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                </svg>
                Sair
              <% end %>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <% if notice %>
      <div class="flash-message fixed top-4 right-4 bg-fz-green-dark text-white px-6 py-3 rounded-lg shadow-lg z-50 animate-fade-in">
        <%= notice %>
      </div>
    <% end %>

    <% if alert %>
      <div class="flash-message fixed top-4 right-4 bg-fz-red-dark text-white px-6 py-3 rounded-lg shadow-lg z-50 animate-fade-in">
        <%= alert %>
      </div>
    <% end %>

    <%= yield %>

    <script>
      // Auto-hide flash messages após 4 segundos
      document.addEventListener('DOMContentLoaded', function() {
        const flashMessages = document.querySelectorAll('.flash-message');
        
        flashMessages.forEach(function(message) {
          setTimeout(function() {
            // Adiciona transição de fade out
            message.style.transition = 'opacity 0.5s ease-out, transform 0.5s ease-out';
            message.style.opacity = '0';
            message.style.transform = 'translateX(100px)';
            
            // Remove o elemento após a animação
            setTimeout(function() {
              message.remove();
            }, 500);
          }, 4000); // 4 segundos
        });
      });

      // Também funciona com Turbo (para navegação SPA do Rails)
      document.addEventListener('turbo:load', function() {
        const flashMessages = document.querySelectorAll('.flash-message');
        
        flashMessages.forEach(function(message) {
          setTimeout(function() {
            message.style.transition = 'opacity 0.5s ease-out, transform 0.5s ease-out';
            message.style.opacity = '0';
            message.style.transform = 'translateX(100px)';
            
            setTimeout(function() {
              message.remove();
            }, 500);
          }, 4000);
        });
      });
    </script>
  </body>
</html>