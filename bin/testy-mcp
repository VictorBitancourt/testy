#!/usr/bin/env ruby
# frozen_string_literal: true

ENV["BUNDLE_GEMFILE"] ||= File.expand_path("../Gemfile", __dir__)
require "bundler/setup"
require "mcp"
require_relative "../lib/testy_mcp/client"
require_relative "../lib/testy_mcp/tools/base"
require_relative "../lib/testy_mcp/tools/auth"
require_relative "../lib/testy_mcp/tools/test_plans"
require_relative "../lib/testy_mcp/tools/test_scenarios"
require_relative "../lib/testy_mcp/tools/bugs"
require_relative "../lib/testy_mcp/tools/tags"
require_relative "../lib/testy_mcp/tools/screenshots"

base_url = ENV.fetch("TESTY_BASE_URL", "http://localhost:3000")
token = ENV["TESTY_API_TOKEN"]
client = TestyMcp::Client.new(base_url: base_url, token: token)

server = MCP::Server.new(
  name: "testy",
  version: "1.0.0",
  tools: [
    TestyMcp::Tools::Login,
    TestyMcp::Tools::ListTestPlans,
    TestyMcp::Tools::GetTestPlan,
    TestyMcp::Tools::CreateTestPlan,
    TestyMcp::Tools::UpdateTestPlan,
    TestyMcp::Tools::DeleteTestPlan,
    TestyMcp::Tools::CreateTestScenario,
    TestyMcp::Tools::UpdateTestScenario,
    TestyMcp::Tools::DeleteTestScenario,
    TestyMcp::Tools::ListBugs,
    TestyMcp::Tools::GetBug,
    TestyMcp::Tools::CreateBug,
    TestyMcp::Tools::UpdateBug,
    TestyMcp::Tools::DeleteBug,
    TestyMcp::Tools::ListTags,
    TestyMcp::Tools::AttachScreenshot,
    TestyMcp::Tools::CaptureScreenshot,
  ],
  server_context: { client: client },
)

transport = MCP::Server::Transports::StdioTransport.new(server)
transport.open
